# Pretalx Configuration for Coolify
# Copy to .env and adjust values

# =============================================================================
# REQUIRED - Change these!
# =============================================================================

# Your pretalx domain (without https://)
# Testing: *.tools.moorwald.com | Production: cfp.mautic.org
PRETALX_DOMAIN=pretalx.tools.moorwald.com

# Database password (generate a secure one!)
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# =============================================================================
# MAIL SETTINGS
# =============================================================================

MAIL_FROM=pretalx@tools.moorwald.com
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
# Set to True for STARTTLS, or use MAIL_SSL=True for implicit TLS
MAIL_TLS=True
MAIL_SSL=False

# =============================================================================
# OPTIONAL
# =============================================================================

# Number of Gunicorn workers (default: 4)
GUNICORN_WORKERS=4

# Set to False for production (requires static file serving via nginx)
PRETALX_DEBUG=True
